{
  "name": "luna-grounding-auditor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify": "npm run audit:prod && npm run test && npm run typecheck && npm run build"
  },
  "dependencies": {
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "typescript": "5.8.3",
    "vitest": "3.1.2"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
